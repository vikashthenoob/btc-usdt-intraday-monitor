# API Configuration
BYBIT_TIMEOUT=10

# Monitoring Configuration
MONITOR_SYMBOL=BTCUSDT
CHECK_INTERVAL=60
MAX_PRICE_HISTORY=500

# Indicator Configuration
SMA_PERIOD=20
RSI_PERIOD=14
BOLLINGER_PERIOD=20
BOLLINGER_STD_DEV=2.0

# Alert Thresholds
RSI_OVERBOUGHT=70
RSI_OVERSOLD=30
LIQUIDATION_THRESHOLD=1000000
FUNDING_RATE_THRESHOLD=0.001

# Alert Configuration
MAX_ALERTS=1000
ALERT_RETENTION=500

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=monitor.log

# Notification Configuration (Optional)
ENABLE_NOTIFICATIONS=false
NOTIFICATION_EMAIL=
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Database Configuration (Optional)
USE_DATABASE=false
DATABASE_URL=sqlite:///monitor.db
